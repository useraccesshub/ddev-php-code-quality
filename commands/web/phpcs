#/usr/bin/env bash
#ddev-generated

## Description: This is a wrapper for the app's phpcs command.
## Usage: phpcs
## Example: ddev phpcs

# See 'set --help' for more information.
set -e

# Check if phpcs is available.
if ! command -v phpcs >/dev/null 2>&1; then
  echo "The phpcs command cannot be found."
  exit 1
fi

# Environment specific variables are set in .ddev/.env.phpcs.
phpcs --config-set default_standard "$PHPCS_DEFAULT_STANDARDS" &> /dev/null
phpcs --config-set extensions "$PHPCS_EXTENSIONS" &> /dev/null
phpcs --config-set ignore_patterns "$PHPCS_IGNORE_PATTERN" &> /dev/null

phpcs $@